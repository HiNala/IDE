# Rust
/target/
**/target/
/target-ws-test/
**/*.rs.bk
*.pdb

# Cargo
# Note: Cargo.lock IS committed for the binary crate (editor-app) per Rust guidelines.
# The workspace-level lock is committed once M01 introduces binary crates.

# IDE / editor temp files
.idea/
.vscode/
.claude/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Build artifacts
*.exe
*.dll
*.so
*.dylib

# Logs and diagnostics
*.log
/logs/
/profiling/
*.profraw
*.profdata
flamegraph.svg
perf.data*

# Criterion benchmark results (kept out of git; regenerated locally/CI)
/target/criterion/
/criterion/

# Coverage
/coverage/
*.gcda
*.gcno
lcov.info

# Secrets — never commit these
.env
.env.*
!.env.example
*.pem
*.key

# OS / shell
/.windsurf/cache/

# Scratch space for human + agent notes that should not ship
/scratch/
/tmp/

# Agent / local alternate Cargo target dirs (never commit)
/target-*/
/_*.txt
/M12_RESTORE_NOTES.txt
/restore_*.ps1
/check_out.txt
/.commit_msg.txt

# Local vector index (derived; `editor-app index --rebuild` regenerates)
.ide/index.sqlite
.ide/index.sqlite-journal
